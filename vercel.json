{
  "version": 2,
  "builds": [
    {
      "src": "react-vulnerable-app/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "build" }
    },
    {
      "src": "react-vulnerable-app/server/server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "react-vulnerable-app/server/server.js"
    },
    {
      "src": "/(.*)",
      "dest": "react-vulnerable-app/$1",
      "continue": true
    }
  ]
}
